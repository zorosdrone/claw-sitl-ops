# Copy this file to ~/.openclaw/workspace/.sitl-ops.env for split operation.

# Python for sitl_mav.py on the OpenClaw host.
SITL_VENV_PYTHON="$HOME/.openclaw/workspace/.venv/bin/python"

# MAVLink endpoint on the remote SITL host over TailScale.
SITL_MASTER="udp:100.64.10.20:14550"

# Remote SSH target for !sitl start / !sitl stop.
# This can be a WSL SSH daemon or a Windows-side SSH endpoint that forwards into WSL.
SITL_REMOTE_SSH_TARGET="user@100.64.10.20"
SITL_REMOTE_SSH_PORT="22"

# Paths on the remote WSL host.
SITL_REMOTE_AP_ROOT="$HOME/ardupilot"
SITL_REMOTE_AP_VENV_ACTIVATE="$HOME/venv-ardupilot/bin/activate"
SITL_REMOTE_START_ARGS="-v Copter -L Kawachi --no-mavproxy --out=0.0.0.0:14550"
SITL_REMOTE_LOG="/tmp/sitl_copter.log"