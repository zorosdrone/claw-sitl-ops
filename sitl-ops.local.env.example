# Copy this file to ~/.openclaw/workspace/.sitl-ops.env for same-host operation.

# Python for sitl_mav.py on the OpenClaw host.
SITL_VENV_PYTHON="$HOME/.openclaw/workspace/.venv/bin/python"

# Same-host MAVLink endpoint.
SITL_MASTER="udp:127.0.0.1:14550"

# Local ArduPilot paths used by !sitl start / !sitl stop.
SITL_AP_ROOT="$HOME/.openclaw/workspace/GitHub/ardupilot"
SITL_AP_VENV_ACTIVATE="$HOME/venv-ardupilot/bin/activate"
SITL_START_ARGS="-v Copter -L Kawachi --no-mavproxy"
SITL_LOG="/tmp/sitl_copter.log"

# Keep remote settings unset for same-host operation.
# SITL_REMOTE_SSH_TARGET=
# SITL_REMOTE_SSH_PORT=22
# SITL_REMOTE_AP_ROOT=
# SITL_REMOTE_AP_VENV_ACTIVATE=
# SITL_REMOTE_START_ARGS=
# SITL_REMOTE_LOG=